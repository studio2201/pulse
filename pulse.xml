<?xml version="1.0"?>
<Container version="2">
  <Name>pulse</Name>
  <Repository>ghcr.io/studio2201/pulse:latest</Repository>
  <Registry>https://ghcr.io/studio2201/pulse</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/studio2201/pulse/issues</Support>
  <Project>https://github.com/studio2201/pulse</Project>
  <Overview>Real-time system health, telemetry, and metrics monitoring dashboard built in Rust.</Overview>
  <Category>Tools:System Network:Management</Category>
  <WebUI>http://[IP]:[PORT:4406]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/studio2201/unraid-templates/master/templates/pulse.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/studio2201/unraid-templates/master/icons/pulse.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>Real-time system health, telemetry, and metrics monitoring dashboard built in Rust.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>4406</HostPort>
        <ContainerPort>4406</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/pulse</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>4406</Value>
      <Name>PORT</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>/config</Value>
      <Name>DATA_DIR</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
  <Config Name="Web UI Port" Target="4406" Default="4406" Mode="tcp" Description="HTTP Web Interface Port" Type="Port" Display="always" Required="true" Mask="false">4406</Config>
  <Config Name="App Storage Directory" Target="/config" Default="/mnt/user/appdata/pulse" Mode="rw" Description="Persistent data and configuration directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/pulse</Config>
</Container>
